# ──────────────────────────────────────────────────
# NEXUS — Environment Variables Template
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# ─── Pi .env (place at /home/pi/.env) ───

# Shared auth token — make up any strong passphrase.
# MUST match the NEXUS_TOKEN in your laptop .env exactly.
# REQUIRED: NEXUS will refuse to start without this.
NEXUS_TOKEN=your-shared-secret-token

# Laptop server connection
LAPTOP_IP=192.168.1.x
LAPTOP_PORT=5000

# Your home city — used as the default for weather queries
# The user can override this at runtime: "I live in Tokyo"
DEFAULT_CITY=London

# AI providers
GROQ_API_KEY=gsk_your_groq_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# TTS (fallback chain: ElevenLabs → Deepgram → Edge-TTS → pyttsx3)
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
# Optional: override the default ElevenLabs voice
# Find voice IDs at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Search & News
TAVILY_API_KEY=tvly-your_tavily_key_here
NEWS_API_KEY=your_newsapi_org_key_here

# Wake word (Picovoice Porcupine)
PORCUPINE_ACCESS_KEY=your_picovoice_access_key_here
PORCUPINE_MODEL_PATH=/home/pi/Hey-Nexus_en_raspberry-pi_v4_0_0.ppn


# ─── Laptop .env (place in project root) ───

# Shared auth token — MUST match the Pi's NEXUS_TOKEN above.
# REQUIRED: server will refuse to start without this.
# NEXUS_TOKEN=your-shared-secret-token

# Spotify OAuth credentials
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback

# Server port (default: 5000 — change only if 5000 is taken on your machine)
# If you change this, update LAPTOP_PORT on the Pi .env too
# LAPTOP_PORT=5000

# System alert thresholds (optional — these are the defaults)
# CPU_ALERT_THRESHOLD=80
# BATTERY_ALERT_THRESHOLD=20
